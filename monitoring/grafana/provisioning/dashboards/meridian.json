{
  "uid": "meridian-overview",
  "title": "Meridian — Query Overview",
  "tags": ["meridian"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Queries / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "rate(meridian_queries_started_total[1m]) * 60",
          "legendFormat": "qpm"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "unit": "percentunit"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(meridian_queries_failed_total[5m]) / (rate(meridian_queries_started_total[5m]) + 1e-9)",
          "legendFormat": "error rate"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "p95 Latency (ms)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(meridian_query_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "unit": "percentunit"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(meridian_queries_started_total[5m]) > 0 and (rate(meridian_queries_started_total[5m]) - rate(meridian_queries_successful_total[5m]) - rate(meridian_queries_failed_total[5m])) / rate(meridian_queries_started_total[5m])",
          "legendFormat": "cache hit rate"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Query Latency Percentiles",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(meridian_query_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meridian_query_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(meridian_query_duration_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Query Throughput (started / successful / failed)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(meridian_queries_started_total[1m])",
          "legendFormat": "started"
        },
        {
          "expr": "rate(meridian_queries_successful_total[1m])",
          "legendFormat": "successful"
        },
        {
          "expr": "rate(meridian_queries_failed_total[1m])",
          "legendFormat": "failed"
        }
      ]
    },

    {
      "id": 7,
      "type": "barchart",
      "title": "Queries by Domain",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "options": {
        "xField": "domain",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum by (domain) (increase(meridian_queries_domain_total[1h]))",
          "legendFormat": "{{domain}}"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Rows Returned per Query (p50 / p95)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(meridian_query_rows_bucket[5m]))",
          "legendFormat": "p50 rows"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meridian_query_rows_bucket[5m]))",
          "legendFormat": "p95 rows"
        }
      ]
    }

  ]
}
