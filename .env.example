# MERIDIAN Configuration
# Copy this file to .env.local and update with your values

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/meridian
DB_ECHO=true

# Application
APP_NAME=MERIDIAN
APP_VERSION=1.0.0
APP_DESCRIPTION=Multi-agent data navigation platform

# API
API_HOST=0.0.0.0
API_PORT=8000

# Security
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=false
LANGSMITH_API_KEY=optional-langsmith-key
LANGSMITH_PROJECT=optional-project-name

# Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
